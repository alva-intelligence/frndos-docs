{
  "name": "frnd-docs",
  "version": "0.1.0",
  "description": "frndOS Help Center — built with Docusaurus + TinaCMS",
  "scripts": {
    "docusaurus": "docusaurus",
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 tinacms dev --datalayer-port 9393 -c \"docusaurus start --port 3333\"",
    "dev:local": "NODE_OPTIONS=--max-old-space-size=8192 tinacms dev --datalayer-port 9393 -c \"docusaurus start --port 3333\"",
    "start": "docusaurus start --port 3333",
    "build": "node scripts/build.js",
    "build:local": "NODE_OPTIONS=--max-old-space-size=8192 tinacms build --local --skip-cloud-checks -c \"docusaurus build\"",
    "build:cloud": "NODE_OPTIONS=--max-old-space-size=8192 tinacms build && docusaurus build",
    "build-local": "npm run build:local",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --port 3333",
    "publish": "node scripts/publish.js",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "3.3.2",
    "@docusaurus/preset-classic": "3.3.2",
    "@easyops-cn/docusaurus-search-local": "^0.44.6",
    "@mdx-js/react": "^3.1.1",
    "@tinacms/cli": "^2.3.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tinacms": "^3.8.1",
    "title": "^3.5.3"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.3.2",
    "agentation": "^3.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=22.0"
  },
  "resolutions": {
    "webpack": "~5.105.0"
  },
  "overrides": {
    "webpack": "~5.105.0"
  },
  "pnpm": {
    "overrides": {
      "webpack": "~5.105.0"
    }
  }
}
